# Budget API Configuration
BUDGET_API_KEY=your-secret-api-key-here-change-this-in-production

# Default admin user (first-time setup only — skipped if any regular users exist)
# Change the password immediately after first login
ADMIN_EMAIL=admin@budget.local
ADMIN_PASSWORD=changeme

# Service user seeding (optional — permanent session token for automation)
# Generate token with: openssl rand -hex 32
SERVICE_USER_EMAIL=service@budget.local
SERVICE_USER_TOKEN=

# Database Configuration
DB_PATH=/data/budget.db

# Timezone (for scheduler calculations)
TZ=Europe/London

# Server Configuration
PORT=8080
GIN_MODE=release 